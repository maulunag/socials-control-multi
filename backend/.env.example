# ============================================================
# Backend Environment Variables — EJEMPLO (sin valores reales)
# ============================================================
# Copia este archivo como .env y completa los valores reales.

# --- Base de datos ---
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# --- JWT ---
JWT_SECRET=change_this_to_a_long_random_secret_key
